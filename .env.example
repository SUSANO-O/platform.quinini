# ════════════════════════════════════════════════════════════════════════════
# MatIAsLanding — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (database: agentflowhub_landing)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/agentflowhub_landing

# ── Auth ─────────────────────────────────────────────────────────────────────
# Random string ≥32 chars — used to sign session tokens
JWT_SECRET=change-me-to-at-least-32-random-characters

# Secret code required by /admin/promote to grant admin role
ADMIN_SECRET=change-me-to-a-strong-secret

# ── App URL ───────────────────────────────────────────────────────────────────
# Public URL of this app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3201

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe secret key (sk_test_* for test, sk_live_* for production)
STRIPE_SECRET_KEY=sk_test_...

# Clave publicable (pk_test_* / pk_live_*) — misma cuenta que STRIPE_SECRET_KEY.
# Necesaria para Stripe Elements (cambiar tarjeta sin salir de la app).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret (cada endpoint tiene su propio whsec_...)
# - Producción / Vercel: npm run stripe:create-webhook -- https://tu-dominio.com
# - Local: crea .env.local con STRIPE_WEBHOOK_SECRET = salida de `npm run stripe:print-secret`
#          y en otra terminal: npm run stripe:listen (reenvío a localhost:3201)
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_PUBLIC_URL=https://tu-landing.vercel.app

# Stripe Price IDs for each plan (Dashboard → Products → Price → copy price_...)
# Deben ser del MISMO modo que STRIPE_SECRET_KEY (test con sk_test_*, live con sk_live_*).
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_BUSINESS=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_...

# From address: the DOMAIN part must be added + verified in https://resend.com/domains
# (DNS en tu proveedor; no hace falta que el servidor sea “local” o público).
# En local: usa el mismo dominio verificado, u otro que ya tengas en Resend.
# Si RESEND_API_KEY está vacío, los correos solo se loguean en consola (sin envío real).
EMAIL_FROM=MatIAs<noreply@yourdomain.com>

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for Widget API requests
# Leave empty to allow all origins (not recommended for production)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── RAG / embeddings en la landing (procesamiento de documentos con Gemini) ─
# Misma familia de clave que uses en el hub si centralizas; obligatoria si usas RAG en esta app.
GEMINI_API_KEY=

# ── Jobs internos (p. ej. Vercel Cron → /api/internal/subscription-reminders) ─
# Sin esto, ese endpoint responde 503. Valor compartido con la cabecera o query ?secret= del cron.
CRON_SECRET=

# ── URLs solo servidor (emails: enlaces y assets) ───────────────────────────
# Origen absoluto para enlaces en correo (si difiere del dominio público).
APP_URL=
# Origen público solo para imágenes en HTML de email (logo); por defecto NEXT_PUBLIC_APP_URL.
EMAIL_PUBLIC_ASSET_BASE=
# Opcional: GIF celebración en /dashboard tras suscripción (URL absoluta o relativa si sirves el asset).
NEXT_PUBLIC_SUBSCRIPTION_HERO_GIF=

# ── Finanzas internas (panel /dashboard/finance) ────────────────────────────
# Fallback global si no se puede clasificar modelo por widget/agente.
FINANCE_EST_USD_PER_MESSAGE=0.003
# Coste por mensaje para modelos económicos (flash/mini/small).
FINANCE_EST_USD_PER_MESSAGE_FLASH=0.0005
# Coste por mensaje para modelos premium (pro/ultra/claude/gpt-4+).
FINANCE_EST_USD_PER_MESSAGE_PREMIUM=0.004
# Multiplicador cuando el agente tiene RAG habilitado.
FINANCE_EST_RAG_MULTIPLIER=1.8

# ── AgentFlowHub / AIBackHub (sync agentes, widget-events, admin Embeddings 3D) ─
# URL base del hub (servidor Express). Debe coincidir con BACKEND_URL en AgentFlowhub.
BACKEND_URL=http://127.0.0.1:9003
# Alias opcional: misma URL si ya usas AUTH_BACKEND_URL en otro despliegue.
AUTH_BACKEND_URL=

# Debe coincidir con API_KEY en AIBackHub/.env (cabecera x-api-key). Vacío solo si el hub no define API_KEY (dev abierto).
AIBACKHUB_API_KEY=
# Identificador de tenant en Mongo del hub (cabecera x-tenant-id). Local típico: default
AIBACKHUB_TENANT_ID=default
# Opcional: si AIBackHub define ADMIN_API_KEY y las rutas /api/admin/* no aceptan solo x-api-key,
# pon aquí la misma clave (la landing la envía como x-admin-key al proxy de /api/admin/embedding-viz).
AIBACKHUB_ADMIN_KEY=

# Secreto compartido: AIBackHub llama a POST /api/internal/sync-from-hub tras editar un agente
# enlazado desde la landing (misma cadena en el hub: HUB_TO_LANDING_SECRET).
HUB_TO_LANDING_SECRET=

# ── AgentFlowhub (Next — proxy de /api/widget/chat desde la landing) ──────────
# El SDK embebido usa host = tu landing; el chat se reenvía al hub para resolver agentes/RAG.
# Sin AgentFlowhub en marcha, Preview/widget devuelve 502 al enviar mensajes.
# En la carpeta AgentFlowhub: npx next dev -p 9002 (o el puerto que pongas aquí).
# AgentFlowhub necesita BACKEND_URL apuntando a AIBackHub (p. ej. 9003).
# Para validar tokens wt_* guardados en Mongo (Mis widgets), en el .env de AgentFlowhub
# pon HUB_TO_LANDING_SECRET igual que arriba y LANDING_INTERNAL_URL a la URL base de esta
# landing (p. ej. http://127.0.0.1:3201).
AGENTFLOWHUB_URL=http://127.0.0.1:9002

# URL pública del UI AgentFlowhub (enlaces «Abrir MCP», Panel Admin → Supervisión → «Abrir granja en Hub»).
# Debe coincidir con el origen donde corre AgentFlowhub en el navegador (no con AGENTFLOWHUB_URL del proxy si difieren).
# Por defecto local: 9010. Si no defines esta variable, el admin usa el mismo fallback que el dashboard MCP.
NEXT_PUBLIC_AGENTFLOWHUB_URL=http://127.0.0.1:9010

# ── MCP estándar (landing — formulario «Conectar integración MCP») ───────────
# URL por defecto del campo «URL del servidor MCP» cuando el usuario elige
# «MCP Server (estándar)» (integrationKey mcp_standard). Debe ser http:// o https://
# accesible desde AIBackHub (BACKEND_URL), no solo desde el navegador.
# Ejemplo local: http://127.0.0.1:8080/mcp
# Déjalo vacío si no quieres pre-rellenar.
NEXT_PUBLIC_MCP_STANDARD_DEFAULT_URL=

# Auditoría fases MCP (A–E) + curl al hub: npm run verify:mcp-phases

# ── API Gateway (optional — playground / API pública) ────────────────────────
# Cliente (browser): mismo host/puerto que GATEWAY_URL si el playground es local.
NEXT_PUBLIC_GATEWAY_URL=http://127.0.0.1:3100
# Servidor (rewrites /api/gateway): URL del gateway.
GATEWAY_URL=http://127.0.0.1:3100

# ════════════════════════════════════════════════════════════════════════════
#  STRIPE + MONGODB — QUÉ REVISAR SI EL PLAN NO SE ACTUALIZA
# ════════════════════════════════════════════════════════════════════════════
#
#  Stripe Dashboard (mismo modo test/live que tu STRIPE_SECRET_KEY)
#  ───────────────────────────────────────────────────────────────────────────
#  • Suscripciones → abre la suscripción → el Price debe ser el que configuraste.
#  • En la suscripción, Metadata: debería incluir plan=starter|growth|business
#    (los nuevos checkouts lo envían vía subscription_data.metadata; suscripciones
#    antiguas pueden no tenerlo hasta que renueves o lo añadas a mano en Stripe).
#  • Developers → Webhooks → endpoint https://TU_DOMINIO/api/webhooks/stripe
#    → el "Signing secret" (whsec_...) es el que va en STRIPE_WEBHOOK_SECRET.
#  • En local: stripe listen --forward-to localhost:PUERTO/api/webhooks/stripe
#    y pega el whsec que muestra la CLI en STRIPE_WEBHOOK_SECRET (no el de producción).
#
#  Customer Portal (opcional — solo si usas “Abrir portal avanzado de Stripe” en Ajustes)
#  ───────────────────────────────────────────────────────────────────────────
#  Tarjeta y facturas in-app: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY + /api/billing/setup-intent e invoices.
#  Si quieres el portal hosted: Stripe Dashboard → Billing → Customer portal → activar y guardar.
#
#  Variables .env (deben ser coherentes entre sí)
#  ───────────────────────────────────────────────────────────────────────────
#  • STRIPE_PRICE_STARTER (etc.) = Price ID exacto (price_...) del producto en Stripe.
#  • Si el price_... no coincide con la suscripción real, el código puede inferir
#    el plan por importe: en código, PLANS usa 19 / 49 / 129 USD → unit_amount 1900,
#    4900, 12900 (centavos). Otro importe/moneda no coincidirá salvo metadata o price ID.
#
#  MongoDB — colección subscriptions (modelo Subscription)
#  ───────────────────────────────────────────────────────────────────────────
#  • userId: mismo string que el _id del usuario en users (sesión).
#  • stripeCustomerId / stripeSubscriptionId: rellenos tras checkout o sync.
#  • plan: free | starter | growth | business | enterprise
#  • status, currentPeriodEnd (epoch segundos, fin de periodo actual en Stripe).
#
# ════════════════════════════════════════════════════════════════════════════
#  PRODUCTION CHECKLIST
# ════════════════════════════════════════════════════════════════════════════
#  [ ] Rotate all secrets before deploying
#  [ ] Use live Stripe keys (sk_live_*) and live webhook signing secret (whsec_*)
#  [ ] Set NEXT_PUBLIC_APP_URL to your production domain
#  [ ] Verify EMAIL_FROM domain in Resend
#  [ ] Set ALLOWED_ORIGINS to your production domains
#  [ ] Register Stripe webhook → https://YOUR_DOMAIN/api/webhooks/stripe
#      Events to enable (must match route handlers):
#        - checkout.session.completed
#        - customer.subscription.created
#        - customer.subscription.updated
#        - customer.subscription.deleted
#        - invoice.paid          (email con factura PDF: alta, cambio de plan, renovación)
#        - invoice.payment_failed
#        - customer.subscription.trial_will_end
